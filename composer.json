{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "akrista/fillakit",
    "type": "project",
    "description": "A laravel starter kit built with filament",
    "keywords": ["laravel", "framework","filamentphp"],
    "license": "MIT",
    "authors": [
        {
            "name": "Jorge Thomas (akrista)",
            "role": "Maintainer",
            "email": "info@notakrista.com",
            "homepage": "https://notakrista.com/fillakit"
        }
    ],
    "require": {
        "php": "^8.5",
        "convergephp/blade-components": "^1.0",
        "convergephp/converge": "^1.0.2",
        "filament/filament": "^5.2.2",
        "filament/spatie-laravel-media-library-plugin": "^5.2.2",
        "filament/spatie-laravel-settings-plugin": "^5.2.2",
        "flowframe/laravel-trend": "^0.4.0",
        "laravel/framework": "^12.52.0",
        "laravel/octane": "^2.13.5",
        "laravel/reverb": "^1.7.1",
        "laravel/sanctum": "^4.3.1",
        "laravel/tinker": "^2.11.1",
        "silviolleite/laravelpwa": "^2.0.3",
        "spatie/laravel-activitylog": "^4.12.0",
        "spatie/laravel-permission": "^6.24.1",
        "spatie/laravel-settings": "^3.7.0",
        "spatie/laravel-translation-loader": "^2.8.3",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "akrista/laravel-extra-boost": "^2.0.2",
        "barryvdh/laravel-ide-helper": "^3.6.1",
        "driftingly/rector-laravel": "^2.1.9",
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.0.9",
        "larastan/larastan": "^3.9.2",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.27.1",
        "laraveldaily/filacheck": "^0.2.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-browser": "^4.3.0",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.3",
        "phpunit/phpunit": "^12.5.12",
        "rector/rector": "^2.3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"bun run dev\" --names='server,queue,vite'"
        ],
        "dev:ssr": [
            "bun run build:ssr",
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan inertia:start-ssr\" --names=server,queue,logs,ssr --kill-others"
        ],
        "prod": [
            "Composer\\Config::disableProcessTimeout",
            "bun run build",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#10b981,#fb7185,#fdba74\" \"php artisan octane:start --host=0.0.0.0\" \"php artisan horizon\" \"php artisan reverb:start\" \"php artisan pail --timeout=0\" --names=server,queue,broadcast,logs,vite --kill-others"
        ],
        "build": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan storage:link",
            "@php artisan filament:upgrade",
            "@php artisan optimize:clear",
            "@php artisan icons:cache",
            "@php artisan filament:cache-components",
            "@php artisan optimize",
            "bun run build"
        ],
        "ide": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models -NR",
            "@php artisan ide-helper:meta"
        ],
        "update:requirements": [
            "Composer\\Config::disableProcessTimeout",
            "composer bump",
            "bunx bun-check-updates -u"
        ],
        "lint": [
            "Composer\\Config::disableProcessTimeout",
            "rector",
            "pint --parallel",
            "pint --parallel --config=pint.filament.json app/Filament",
            "bun run lint"
        ],
        "test:lint": [
            "Composer\\Config::disableProcessTimeout",
            "pint --parallel --test",
            "pint --parallel --test --config=pint.filament.json app/Filament",
            "rector --dry-run",
            "bun run test:lint"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0",
        "test:types": "phpstan",
        "test": [
            "@php artisan config:clear --ansi",
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",  "@php artisan extra-boost:update --ansi",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models -NR",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('storage/sqlite/fillakit.sqlite') || touch('storage/sqlite/fillakit.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}