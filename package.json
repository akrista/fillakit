{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "name": "akrista/fillakit",
    "author": "Jorge Thomas (akrista) <info@notakrista.com> (https://notakrista.com/)",
   "license": "MIT",
    "licenseUrl": "http://github.com/akrista/fillakit",
    "homepage": "https://github.com/akrista/fillakit",
    "bugs": {
        "url": "https://github.com/akrista/fillakit/issues"
    },
    "keywords": [
        "filamentphp",
        "laravel",
        "typescript",
        "vite"
    ],
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "test:lint": "eslint . && prettier --check resources/",
        "test:types": "svelte-check --tsconfig ./tsconfig.json"
    },
    "dependencies": {
        "driver.js": "^1.4.0",
        "laravel-echo": "^2.2.6",
        "pusher-js": "^8.4.0",
        "@inertiajs/svelte": "^2.0.0",
        "@sveltejs/vite-plugin-svelte": "^6.0.0",
        "@tailwindcss/vite": "^4.1.11",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "svelte": "^5.16.0",
        "tailwind-merge": "^3.2.0",
        "typescript": "^5.7.2"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "concurrently": "^9.0.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "laravel-vite-plugin": "^2.0.0",
        "@types/node": "^22.13.5",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-svelte": "^3.1.0",
        "npm-check-updates": "^19.3.2",
        "playwright": "^1.58.2",
        "prettier": "^3.4.2",
        "prettier-plugin-svelte": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "prettier-plugin-organize-imports": "^4.3.0",
        "svelte-check": "^4.1.4",
        "tailwindcss": "^4.1.1",
        "vite": "^7.0.4",
        "typescript-eslint": "^8.23.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1"
    }
}
