{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "name": "akrista/fillakit",
    "author": "Jorge Thomas (akrista) <info@notakrista.com> (https://notakrista.com/)",
    "license": "MIT",
    "licenseUrl": "http://github.com/akrista/fillakit",
    "homepage": "https://github.com/akrista/fillakit",
    "bugs": {
        "url": "https://github.com/akrista/fillakit/issues"
    },
    "keywords": [
        "filamentphp",
        "laravel",
        "typescript",
        "vite"
    ],
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "lint": "eslint . --fix",
        "test:lint": "eslint . && prettier --check resources/",
        "test:types": "svelte-check --tsconfig ./tsconfig.json"
    },
    "dependencies": {
        "driver.js": "^1.4.0",
        "laravel-echo": "^2.3.0",
        "pusher-js": "^8.4.0",
        "@inertiajs/svelte": "^2.3.15",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/vite": "^4.2.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "svelte": "^5.53.2",
        "tailwind-merge": "^3.5.0",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.3",
        "concurrently": "^9.2.1",
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
        "laravel-vite-plugin": "^2.1.0",
        "@types/node": "^22.19.11",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-svelte": "^3.15.0",
        "npm-check-updates": "^19.4.1",
        "playwright": "^1.58.2",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "prettier-plugin-organize-imports": "^4.3.0",
        "svelte-check": "^4.4.3",
        "tailwindcss": "^4.2.0",
        "vite": "^7.3.1",
        "typescript-eslint": "^8.56.0"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.2.0",
        "lightningcss-linux-x64-gnu": "^1.31.1"
    }
}
